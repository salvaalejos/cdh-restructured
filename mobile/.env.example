# CDH Mobile — Environment Variables
# Para desarrollo local con el emulador Android, usa 10.0.2.2 (alias de 127.0.0.1 del host)
# Para producción, cambia esta URL por la IP/dominio real del VPS
# NOTA: Expo solo inyecta variables con prefijo EXPO_PUBLIC_ al bundle del cliente
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:3000/api

# Contraseña para el panel de emergencia (exportar BD local y recuperar progreso)
EXPO_PUBLIC_EMERGENCY_PASSWORD=changeme
